{
  "@context": "https://schema.org",
  "@type": "ExhibitionEvent",
  "@id": "https://maginari.com/exhibitions/{exhibition-slug}#exhibition",
  "name": "{Exhibition Title}",
  "description": "{1-2 sentence canonical-voice description of the exhibition.}",
  "url": "https://maginari.com/exhibitions/{exhibition-slug}",
  "image": "https://maginari.com/assets/exhibitions/{exhibition-slug}.jpg",
  "startDate": "2026-01-01",
  "endDate": "2026-03-31",
  "eventStatus": "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OnlineEventAttendanceMode",
  "location": {
    "@type": "VirtualLocation",
    "url": "https://maginari.com/exhibitions/{exhibition-slug}"
  },
  "organizer": { "@id": "https://maginari.com/#maginari" },
  "isAccessibleForFree": true,
  "workFeatured": [
    { "@id": "https://maginari.com/collections/{collection-slug}#collection" }
  ],
  "performer": [
    { "@id": "https://maginari.com/creative-directors/{director-slug}#person" }
  ]
}
